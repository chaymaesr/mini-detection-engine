{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "System Event Schema",
  "description": "Format de représentation des événements système pour le moteur de détection",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "timestamp", "type", "user", "detail"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Identifiant unique de l'événement",
        "example": "EVT-0001"
      },
      "timestamp": {
        "type": "string",
        "format": "date-time",
        "description": "Horodatage ISO 8601 de l'événement",
        "example": "2024-11-15T08:01:12Z"
      },
      "type": {
        "type": "string",
        "enum": [
          "auth_failure",
          "auth_success",
          "process_exec",
          "suid_exec",
          "file_write",
          "file_read",
          "dns_query",
          "net_connect",
          "port_scan",
          "service_enum",
          "privilege_change"
        ],
        "description": "Catégorie de l'événement système"
      },
      "user": {
        "type": "string",
        "description": "Utilisateur système à l'origine de l'événement",
        "example": "www-data"
      },
      "process": {
        "type": "string",
        "description": "Nom du processus impliqué",
        "example": "sshd"
      },
      "detail": {
        "type": "string",
        "description": "Description détaillée de l'action effectuée",
        "example": "ssh login failed for user root from 192.168.1.42"
      },
      "source_ip": {
        "type": "string",
        "description": "Adresse IP source si applicable",
        "example": "192.168.1.42"
      },
      "pid": {
        "type": "integer",
        "description": "Identifiant du processus (PID)"
      }
    }
  }
}
